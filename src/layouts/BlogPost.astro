---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import '../styles/blog-post.css';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="zh-cn">
	<head>
		<meta name="view-transition" content="same-origin" />
		<BaseHead title={title} description={description} />
		<style is:global>
			/* 目录样式 + 高亮竖线 */
			#toc-list {
				padding-left: 1em;
				margin: 0;
				list-style: none;
				max-height: calc(100vh - 120px); /* 减去头部和边距的空间 */
				overflow-y: auto;
				/* 隐藏滚动条 */
				-ms-overflow-style: none;  /* IE and Edge */
				scrollbar-width: none;  /* Firefox */
			}
			/* 隐藏 Webkit 浏览器的滚动条 */
			#toc-list::-webkit-scrollbar {
				display: none;
			}
			
			#toc-list li {
				margin: 0.4rem 0;
				width: 100%;
			}
			#toc-list li div {
				display: block;
				width: 100%;
				padding: 0.5rem 0.8rem;
				margin-left: -0.8rem;
				color: inherit;
				text-decoration: none;
				cursor: pointer;
				border-left: 4px solid transparent;
				transition: border-left-color 0.2s ease;
			}
			#toc-list li.toc-level-h3 div{
				padding-left: 2rem;
			}
			#toc-list li.active div {
				border-left-color: #9d93b8;
				font-weight: 500;
			}
			#toc-list li div:hover {
				border-left-color: #c4c4c4;
			}
			.toc-empty {
				color: #999;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image fade-in">
					{heroImage && <Image width={200} height={200} src={heroImage} alt="" />}
				</div>

				<div class="three-col-container fade-in">
					<aside class="toc-sidebar fade-in">
						<h3>目录</h3>
						<ul id="toc-list"></ul>
					</aside>

					<div class="prose">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)}
							</div>
							<h1>{title}</h1>
							<hr />
						</div>
						<slot />
					</div>

					<aside class="desc-sidebar fade-in">
						<p set:html={description}></p>
					</aside>
				</div>
			</article>
		</main>
		<Footer />

		<script>
	// 存储标题与目录项的对应关系
	const headingElements = [];
	const tocItemElements = [];

	// 监听页面加载（Astro 专属）
	document.addEventListener('astro:page-load', initToc);
	document.addEventListener('DOMContentLoaded', initToc);

	// 1. 初始化目录
	function initToc() {
		buildToc();
		setupScrollSpy();
	}

	// 2. 生成目录
	function buildToc() {
		const tocList = document.getElementById('toc-list');
		if (!tocList) return;
		
		// 清空之前的目录
		tocList.innerHTML = '';
		headingElements.length = 0;
		tocItemElements.length = 0;

		// 只获取文章内容里的 h2、h3
		const headings = document.querySelectorAll('.prose h2, .prose h3');
		if (headings.length === 0) {
			tocList.innerHTML = '<li class="toc-empty">暂无目录</li>';
			return;
		}

		headings.forEach((heading, index) => {
			// 设置ID用于跳转
			const id = `heading-${index}`;
			heading.id = id;

			// 创建目录项
			const li = document.createElement('li');
			if (heading.tagName === 'H3') li.classList.add('toc-level-h3');
			
			const div = document.createElement('div');
			div.style.cursor = 'pointer';
			// 点击跳转 + 强制刷新高亮
			div.onclick = () => {
				location.hash = id;
				heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
				scrollTocToView(li);
				// 点击后立刻更新高亮（关键修复）
				setTimeout(updateActive, 100);
			};
			div.textContent = heading.textContent.trim();
			li.appendChild(div);
			tocList.appendChild(li);

			// 存入数组
			headingElements.push({ element: heading, tocItem: li });
			tocItemElements.push(li);
		});
	}

	// 滚动目录项到可视区域
	function scrollTocToView(tocItem) {
		const tocList = document.getElementById('toc-list');
		if (!tocList || !tocItem) return;
		
		const listTop = tocList.scrollTop;
		const listHeight = tocList.clientHeight;
		const itemTop = tocItem.offsetTop;
		const itemHeight = tocItem.offsetHeight;
		
		if (itemTop < listTop) {
			tocList.scrollTo({ top: itemTop, behavior: 'smooth' });
		} else if (itemTop + itemHeight > listTop + listHeight) {
			tocList.scrollTo({ top: itemTop - listHeight + itemHeight, behavior: 'smooth' });
		}
	}

	// 3. 滚动监听：自动高亮当前章节（修复版）
	let ticking = false;
	function setupScrollSpy() {
		window.addEventListener('scroll', () => {
			if (!ticking) {
				requestAnimationFrame(updateActive);
				ticking = true;
			}
		});
		updateActive();
	}

	// 高亮更新逻辑（完全重写，精准稳定）
	function updateActive() {
		let bestMatchIndex = -1;
		const scrollY = window.scrollY;
		const offset = 0; // 标题触发位置：距离顶部 120px（可微调）

		// 从后往前找：最后一个进入激活区的标题 = 当前阅读标题
		for (let i = headingElements.length - 1; i >= 0; i--) {
			const heading = headingElements[i].element;
			const top = heading.offsetTop;

			if (scrollY + offset >= top) {
				bestMatchIndex = i;
				break;
			}
		}

		// 更新高亮
		tocItemElements.forEach(item => item.classList.remove('active'));
		if (bestMatchIndex !== -1) {
			const active = tocItemElements[bestMatchIndex];
			active.classList.add('active');
			scrollTocToView(active);
		}

		ticking = false;
	}
</script>
		<script src="../styles/animations/fade-in-on-scroll"></script>
	</body>
</html>