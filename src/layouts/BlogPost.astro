---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

---

<html lang="zh-cn">
	<head>
		<meta name="view-transition" content="same-origin" />
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 95%;
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
				text-align: center;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}

			.article {
				width: 100%;
				margin: 0 auto;
				overflow-x: hidden;		
			}

			/* 三栏布局 */
			.three-col-container {
				display: flex;
				justify-content: center;
				align-items: flex-start;
				/* overflow-x: auto; */
				width: 100%;
			}

			/* 左侧目录 */
			.toc-sidebar {
				width: 15%;
				min-width: 0;
				max-width: 15%;
				position: sticky;
				top: 2rem;
				padding: 0.5rem;
				border-radius: 10px;
				line-height: 1.3;
				font-size: 0.8em;
				background: transparent;
				word-break: break-all;
				max-height: calc(100vh - 4rem);
				overflow-y: auto;
				scrollbar-width: none;
				font-family: "Palatino Linotype", "KaiTi", "STKaiti", "楷体", "华文楷体", var(--font-atkinson);
			}
			.toc-sidebar h3 {
				margin-top: 0;
				font-size: 1rem;
				font-weight: bold;
			}

			/* 中间正文 */
			.prose {
				width: 70%;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}

			/* 右侧描述 */
			.desc-sidebar {
				width: 15%;
				min-width: 0;
				max-width: 15%;
				position: sticky;
				top: 2rem;
				padding: 0.5rem;
				border-radius: 10px;
				line-height: 2;
				font-size: 0.8em;
				word-break: break-all;
				max-height: calc(100vh - 4rem);
				overflow-y: auto;
				scrollbar-width: none;
				text-indent: 2em; 
				margin: 0 0 1em 0;
				overflow-wrap: break-word;
				font-family: "Palatino Linotype", "KaiTi", "STKaiti", "楷体", "华文楷体", var(--font-atkinson);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image fade-in">
					{heroImage && <Image width={200} height={200} src={heroImage} alt="" />}
				</div>

				<div class="three-col-container fade-in">
					<!-- 左侧目录（自动生成） -->
					<aside class="toc-sidebar fade-in">
					<h3>目录</h3>
					<ul id="toc-list" style="padding-left: 1em; margin:0; list-style: none;"></ul>
					<script>
					document.addEventListener('astro:page-load', () => {
					buildToc();
					});

					// 首次加载
					document.addEventListener('DOMContentLoaded', buildToc);

					function buildToc() {
					const tocList = document.getElementById('toc-list');
					if (!tocList) return;

					// 清空旧目录
					tocList.innerHTML = '';

					const headings = document.querySelectorAll('.prose h2, .prose h3');
					if (headings.length === 0) {
						tocList.innerHTML = '<li style="color:#999;">暂无目录</li>';
						return;
					}

					headings.forEach((heading, index) => {
						const id = `heading-${index}`;
						heading.id = id;

						const li = document.createElement('li');
						li.style.margin = '0.4rem 0';
						li.style.width = '100%';

						if (heading.tagName === 'H3') li.style.paddingLeft = '1rem';

						li.innerHTML = `
							<a href="#${id}" style="
							display: block;
							width: 100%;
							padding: 0.5rem 0.8rem;
							margin-left: -0.8rem;
							border-radius: 6px;
							color: inherit;
							text-decoration: none;
							cursor: pointer;
							"
							onmouseover="this.style.border='1px solid #666';this.style.borderRadius='8px';"
							onmouseout="this.style.border='none';this.style.borderRadius='0';">
							${heading.textContent.trim()}
							</a>`;

						tocList.appendChild(li);
						});
					}
					</script>
					</aside>

					<!-- 中间正文 -->
					<div class="prose">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)}
							</div>
							<h1>{title}</h1>
							<hr />
						</div>
						<slot />
					</div>

					<!-- 右侧描述 -->
					<aside class="desc-sidebar fade-in">
						<p set:html={description}></p>
					</aside>
				</div>
			</article>
		</main>
		<Footer />

		<script src="../styles/animations/fade-in-on-scroll"></script>
	</body>
</html>