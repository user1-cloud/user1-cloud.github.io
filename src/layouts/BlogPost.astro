---
// 博客文章布局组件 - 三栏可折叠双侧栏版本
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import LeftSidebar from '../components/LeftSidebar.astro';
import { resolveDirs } from '../lib/utils';

import SearchModal from '../components/SearchModal.astro';

// 专用css
import '../styles/_sidebar.scss';
import '../styles/blog-post.scss';
import '../styles/left-sidebar.scss';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, heroImage, dir1, dir2, tags = [] } = Astro.props;

// 构建左侧栏数据
const allPosts = await getCollection('blog');
const sidebarData = allPosts.map(post => {
  const dirs = resolveDirs(post);
  return {
    title: post.data.title,
    slug: post.id,
    pubDate: post.data.pubDate,
    dir1: dirs.dir1,
    dir2: dirs.dir2,
    tags: post.data.tags || [],
  };
});
const slugMatch = Astro.url.pathname.match(/^\/blog\/(.+)/);
const currentSlug = slugMatch ? decodeURIComponent(slugMatch[1].replace(/\/+$/, '')) : '';
---

<html lang="zh-cn" class="sidebar-collapsed left-sidebar-collapsed">
	<head>
		<BaseHead title={title} description={description} />
		<slot name="head" />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image fade-in">
					{heroImage && <Image width={200} height={200} src={heroImage} alt="" />}
				</div>

				<!-- 三栏布局容器 -->
				<div class="three-col-layout">
					<!-- 左侧：可折叠侧边栏（目录树 / 标签树） -->
					<LeftSidebar posts={sidebarData} currentSlug={currentSlug} />

					<!-- 中间：正文区域 -->
					<div class="content-main fade-in">
						<div class="prose">
							<div class="title">
								<div class="date">
									<FormattedDate date={pubDate} />
									{updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)}
								</div>
								<h1>{title}</h1>
								{(dir1 || tags.length > 0) && (
									<div class="post-meta">
										{dir1 && (
											<span class="post-category">
												分类：<a href={`/blog/category/${dir1}/`}>{dir1}</a>
												{dir2 && <span> / <a href={`/blog/category/${dir1}/${dir2}/`}>{dir2}</a></span>}
											</span>
										)}
										{tags.length > 0 && (
											<span class="post-tags">
												{tags.map(tag => (
													<a href={`/blog/tag/${encodeURIComponent(tag)}/`} class="tag-pill">{tag}</a>
												))}
											</span>
										)}
									</div>
								)}
								<hr />
							</div>
							<slot />
						</div>
					</div>

					<!-- 右侧：可折叠侧边栏（目录 + 简介） -->
					<aside class="right-sidebar sidebar-panel" id="rightSidebar">
						<div class="sidebar-inner">
							<!-- 上栏：目录区 -->
							<div class="toc-area">
								<div class="position-indicator"></div>
								<h3>目录</h3>
								<ul id="toc-list"></ul>
							</div>
							<hr/>
							<!-- 下栏：简介区 -->
							<div class="desc-area">
								<p set:html={description}></p>
							</div>
						</div>
					</aside>
				</div>
			</article>
		</main>
		<Footer />

		<!-- 左侧栏折叠按钮 -->
		<button class="toggle-left-sidebar-btn sidebar-toggle-btn" id="toggleLeftSidebarBtn" aria-label="切换左侧栏">
			<span class="arrow-icon"></span>
		</button>

		<!-- 右侧栏折叠按钮 -->
		<button class="toggle-right-sidebar-btn sidebar-toggle-btn" id="toggleSidebarBtn" aria-label="切换侧边栏">
			<span class="arrow-icon"></span>
		</button>

		<!-- 移动端左侧栏覆盖层背景 -->
		<div class="left-sidebar-overlay-backdrop"></div>

		<SearchModal />

		<!-- 左侧栏脚本 -->
		<script src="../scripts/left-sidebar"></script>
		<!-- 目录生成脚本 -->
		<script src="../scripts/toc"></script>
		<!-- 滚动渐现效果 -->
		<script src="../scripts/fade-in-on-scroll"></script>

		<script>
			function initSidebar() {
				const storageKey = 'blog-sidebar-collapsed';
				const btn = document.getElementById('toggleSidebarBtn');
				if (!btn) return;

				// 1. 每次都重新读取 localStorage 状态
				const savedState = localStorage.getItem(storageKey);
				const isCollapsed = savedState === 'true';

				// 2. 强制同步状态到页面
				if (isCollapsed) {
					document.documentElement.classList.add('sidebar-collapsed');
				} else {
					document.documentElement.classList.remove('sidebar-collapsed');
				}

				// 3. 点击切换
				function toggleSidebar() {
					document.documentElement.classList.toggle('sidebar-collapsed');
					const nowCollapsed = document.documentElement.classList.contains('sidebar-collapsed');
					localStorage.setItem(storageKey, nowCollapsed);
				}

				// 安全绑定
				btn.removeEventListener('click', toggleSidebar);
				btn.addEventListener('click', toggleSidebar);
			}

			// 初始化
			initSidebar();

			// 路由切换后重新初始化
			document.addEventListener('astro:after-swap', initSidebar);
		</script>
	</body>
</html>
