---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import '../styles/blog-post.css';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

---

<html lang="zh-cn">
	<head>
		<meta name="view-transition" content="same-origin" />
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image fade-in">
					{heroImage && <Image width={200} height={200} src={heroImage} alt="" />}
				</div>

				<div class="three-col-container fade-in">
					<!-- 左侧目录（自动生成） -->
					<aside class="toc-sidebar fade-in">
					<h3>目录</h3>
					<ul id="toc-list" style="padding-left: 1em; margin:0; list-style: none;"></ul>
					<script>
					document.addEventListener('astro:page-load', () => {
					buildToc();
					});

					// 首次加载
					document.addEventListener('DOMContentLoaded', buildToc);

					function buildToc() {
					const tocList = document.getElementById('toc-list');
					if (!tocList) return;

					// 清空旧目录
					tocList.innerHTML = '';

					const headings = document.querySelectorAll('.prose h2, .prose h3');
					if (headings.length === 0) {
						tocList.innerHTML = '<li style="color:#999;">暂无目录</li>';
						return;
					}

					headings.forEach((heading, index) => {
						const id = `heading-${index}`;
						heading.id = id;

						const li = document.createElement('li');
						li.style.margin = '0.4rem 0';
						li.style.width = '100%';

						if (heading.tagName === 'H3') li.style.paddingLeft = '1rem';

						li.innerHTML = `
							<a href="#${id}" style="
							display: block;
							width: 100%;
							padding: 0.5rem 0.8rem;
							margin-left: -0.8rem;
							color: inherit;
							text-decoration: none;
							cursor: pointer;
							border-left: 2px solid transparent;
							"
							onmouseover="this.style.borderLeftColor='#666';"
							onmouseout="this.style.borderLeftColor='transparent'";>
							${heading.textContent.trim()}
							</a>`;

						tocList.appendChild(li);
						});
					}
					</script>
					</aside>

					<!-- 中间正文 -->
					<div class="prose">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)}
							</div>
							<h1>{title}</h1>
							<hr />
						</div>
						<slot />
					</div>

					<!-- 右侧描述 -->
					<aside class="desc-sidebar fade-in">
						<p set:html={description}></p>
					</aside>
				</div>
			</article>
		</main>
		<Footer />

		<script src="../styles/animations/fade-in-on-scroll"></script>
	</body>
</html>