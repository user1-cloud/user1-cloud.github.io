---
// 博客文章布局组件 - 三栏可折叠双侧栏版本
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/layout/BaseHead.astro';
import Footer from '../components/layout/Footer.astro';
import FormattedDate from '../components/blog/FormattedDate.astro';
import Header from '../components/layout/Header.astro';
import SidebarLeft from '../components/layout/SidebarLeft.astro';
import SidebarRight from '../components/layout/SidebarRight.astro';
import { getSidebarData } from '../lib/blogData';

import SearchModal from '../components/blog/SearchModal.astro';

// 专用css
import '../styles/sidebar-collapse.scss';
import '../styles/sidebar-toc.scss';
import '../styles/blog-post.scss';
import '../styles/sidebar-tree.scss';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, heroImage, dir1, dir2, tags = [] } = Astro.props;

// 构建左侧栏数据
const sidebarData = await getSidebarData();
const slugMatch = Astro.url.pathname.match(/^\/blog\/(.+)/);
const currentSlug = slugMatch ? decodeURIComponent(slugMatch[1].replace(/\/+$/, '')) : '';
---

<html lang="zh-cn" class="sidebar-collapsed left-sidebar-collapsed">
	<head>
		<BaseHead title={title} description={description} />
		<slot name="head" />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image fade-in">
					{heroImage && <Image width={200} height={200} src={heroImage} alt="" />}
				</div>

				<!-- 三栏布局容器 -->
				<div class="three-col-layout">
					<!-- 左侧：可折叠侧边栏（目录树 / 标签树） -->
					<SidebarLeft posts={sidebarData} currentSlug={currentSlug} />

					<!-- 中间：正文区域 -->
					<div class="content-main fade-in">
						<div class="prose">
							<div class="title">
								<div class="date">
									<FormattedDate date={pubDate} />
									{updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)}
								</div>
								<h1>{title}</h1>
								{(dir1 || tags.length > 0) && (
									<div class="post-meta">
										{dir1 && (
											<span class="post-category">
												分类：<a href={`/blog/category/${dir1}/`}>{dir1}</a>
												{dir2 && <span> / <a href={`/blog/category/${dir1}/${dir2}/`}>{dir2}</a></span>}
											</span>
										)}
										{tags.length > 0 && (
											<span class="post-tags">
												{tags.map(tag => (
													<a href={`/blog/tag/${encodeURIComponent(tag)}/`} class="tag-pill">{tag}</a>
												))}
											</span>
										)}
									</div>
								)}
								<hr />
							</div>
							<slot />
						</div>
					</div>

					<!-- 右侧：可折叠侧边栏（目录 + 简介） -->
					<SidebarRight description={description} />
				</div>
			</article>
		</main>
		<Footer />

		<SearchModal />

		<!-- 左侧栏交互脚本 -->
		<script src="../scripts/sidebar-tree"></script>
		<!-- 目录生成脚本 -->
		<script src="../scripts/toc"></script>
		<!-- 滚动渐现效果 -->
		<script src="../scripts/fade-in-on-scroll"></script>
		<!-- Mermaid 图表渲染 -->
		<script src="../scripts/mermaid"></script>
	</body>
</html>
