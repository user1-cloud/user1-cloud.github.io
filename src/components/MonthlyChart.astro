---
// 月度发文统计折线图（纯 SVG）
interface Props {
  labels: string[];
  counts: number[];
}

const { labels, counts } = Astro.props;

const PAD_LEFT = 40;
const PAD_RIGHT = 20;
const PAD_TOP = 20;
const PAD_BOTTOM = 40;
const WIDTH = 720;
const HEIGHT = 260;
const CHART_W = WIDTH - PAD_LEFT - PAD_RIGHT;
const CHART_H = HEIGHT - PAD_TOP - PAD_BOTTOM;

const hasData = labels.length > 0 && counts.some((c) => c > 0);
const maxCount = hasData ? Math.max(...counts, 1) : 1;

// Y-axis ticks
const yTicks = 5;
function x(i: number) { return PAD_LEFT + (i / Math.max(labels.length - 1, 1)) * CHART_W; }
function y(v: number) { return PAD_TOP + CHART_H - (v / maxCount) * CHART_H; }

const points = counts.map((v, i) => `${x(i)},${y(v)}`);
const dLine = points.join(' ');
const dArea = hasData ? `M${x(0)},${y(0)} L${dLine.slice(dLine.indexOf(' '))} L${x(counts.length - 1)},${PAD_TOP + CHART_H} L${x(0)},${PAD_TOP + CHART_H} Z` : '';
---

<div class="monthly-chart-card stat-card fade-up-on-scroll">
  <div class="stat-label" style="text-align:center;margin-bottom:0.5rem;">月度发文统计</div>
  {hasData ? (
    <svg viewBox={`0 0 ${WIDTH} ${HEIGHT}`} class="mc-svg" aria-label="月度发文折线图">
      <!-- Y-axis grid lines + labels -->
      {Array.from({ length: yTicks }, (_, i) => {
        const val = Math.round((maxCount / (yTicks - 1)) * i);
        const yy = y(val);
        return (
          <g>
            <line x1={PAD_LEFT} y1={yy} x2={WIDTH - PAD_RIGHT} y2={yy} stroke="var(--border)" stroke-width="0.5" />
            <text x={PAD_LEFT - 6} y={yy + 4} text-anchor="end" fill="var(--foreground-dark)" font-size="11">{val}</text>
          </g>
        );
      })}

      <!-- Area fill -->
      <path d={dArea} fill="rgba(var(--accent-rgb), 0.12)" />

      <!-- Line -->
      <polyline points={dLine} fill="none" stroke="var(--accent)" stroke-width="2" stroke-linejoin="round" />

      <!-- Dots -->
      {counts.map((v, i) => (
        <circle cx={x(i)} cy={y(v)} r="3.5" fill="var(--accent)" stroke="var(--background)" stroke-width="1.5">
          <title>{labels[i]}: {v} 篇</title>
        </circle>
      ))}

      <!-- X-axis labels -->
      {labels.map((label, i) => (
        <text x={x(i)} y={HEIGHT - 10} text-anchor="middle" fill="var(--foreground-dark)" font-size="10">{label}</text>
      ))}
    </svg>
  ) : (
    <div class="mc-empty">暂无数据</div>
  )}
</div>

<style>
  .monthly-chart-card {
    padding: 1.5rem;
    margin: 0 auto;
    max-width: 760px;
    width: 100%;
    box-sizing: border-box;
  }

  .mc-svg {
    width: 100%;
    height: auto;
  }

  .mc-empty {
    text-align: center;
    color: var(--foreground-dark);
    padding: 2rem;
  }
</style>
