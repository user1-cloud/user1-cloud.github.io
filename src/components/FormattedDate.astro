---
interface Props {
	date: Date;
}

const { date } = Astro.props;
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString('zh-CN', {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		}).replace(/(\d+)年/, '$1 年 ').replace(/(\d+)月/, '$1 月 ').replace(/(\d+)日/, '$1 日 ')
	}
</time>
