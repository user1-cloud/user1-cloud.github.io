---
// Astro 极致丝滑的 CSS 流动光晕背景组件（随机位置与路径版）
---

<div class="fluid-background">
  <div class="glow-blob blob-1"></div>
  <div class="glow-blob blob-2"></div>
  <div class="glow-blob blob-3"></div>
</div>

<style>
  .fluid-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
    background: #000123;
    overflow: hidden;
  }

  .fluid-background::after {
    content: '';
    position: absolute;
    inset: 0;
    backdrop-filter: blur(80px);
    -webkit-backdrop-filter: blur(80px);
    z-index: 1;
  }

  .glow-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.7;
    z-index: 0;
    will-change: transform;
  }

  /* 蓝色光斑 */
  .blob-1 {
    width: 50vw;
    height: 50vw;
    background: #1f3456;
    /* 使用 CSS 变量控制初始位置 */
    top: var(--start-top);
    left: var(--start-left);
    /* 动画时长也可以稍微随机，这里保持原样或用变量均可 */
    animation: float-generic 20s ease-in-out infinite alternate;
    animation-delay: var(--delay); /* 随机延迟，打破同步感 */
  }

  /* 紫色光斑 */
  .blob-2 {
    width: 40vw;
    height: 40vw;
    background: #311e4f;
    top: var(--start-top);
    left: var(--start-left);
    animation: float-generic 22s ease-in-out infinite alternate;
    animation-delay: var(--delay);
  }

  /* 青绿色光斑 */
  .blob-3 {
    width: 35vw;
    height: 35vw;
    background: #153b37;
    top: var(--start-top);
    left: var(--start-left);
    animation: float-generic 25s ease-in-out infinite alternate;
    animation-delay: var(--delay);
  }

  /* 统一定义漂浮轨迹，通过变量控制偏移量 */
  @keyframes float-generic {
    0% { transform: translate(0, 0) scale(1); }
    100% { 
      /* 使用变量控制漂浮的终点位置，实现路径随机 */
      transform: translate(var(--move-x), var(--move-y)) scale(1.1); 
    }
  }
</style>

<script>
  // 页面加载后执行，为每个光斑注入随机变量
  document.addEventListener('DOMContentLoaded', () => {
    const blobs = document.querySelectorAll('.glow-blob');
    
    blobs.forEach(blob => {
      // 1. 随机初始位置 (0% ~ 80% 之间，防止光斑完全溢出屏幕)
      const startTop = Math.random() * 80;
      const startLeft = Math.random() * 80;
      
      // 2. 随机漂浮路径 (向任意方向移动 -30vw ~ 30vw)
      const moveX = (Math.random() - 0.5) * 60 + 'vw';
      const moveY = (Math.random() - 0.5) * 60 + 'vh';
      
      // 3. 随机动画延迟 (0 ~ 5秒)，让它们的运动节奏错开
      const delay = Math.random() * 5 + 's';

      // 将计算好的值赋给 CSS 变量
      blob.style.setProperty('--start-top', `${startTop}%`);
      blob.style.setProperty('--start-left', `${startLeft}%`);
      blob.style.setProperty('--move-x', moveX);
      blob.style.setProperty('--move-y', moveY);
      blob.style.setProperty('--delay', delay);
    });
  });
</script>