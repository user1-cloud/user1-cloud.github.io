<div class="fluid-background">
  <div class="glow-blob blob-1"></div>
  <div class="glow-blob blob-2"></div>
  <div class="glow-blob blob-3"></div>
  <div class="vignette"></div>
</div>

<style>
  @import "../styles/global.scss";

  .fluid-background {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: var(--background);
    overflow: hidden;
  }

  .glow-blob {
    position: absolute;
    border-radius: 50%;
    z-index: 0;
    /* 初始位置由 JS 设定 top/left */
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, var(--blob-color) 0%, transparent 60%);
    opacity: 0.85;
    /* 核心：同时应用 X 和 Y 两个方向的无限循环动画 */
    animation-name: floatX, floatY, breathe; 
    animation-iteration-count: infinite, infinite, infinite;
    animation-direction: alternate, alternate, alternate; /* 来回摆动更平滑 */
    animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1); /* 标准的平滑贝塞尔曲线 */
  }

  /* 蓝色光斑 */
  .blob-1 {
    width: 80vw; height: 80vw;
    --blob-color: rgba(31, 52, 86, 0.6);
    /* 基础动画时长，JS会在此基础上微调 */
    animation-duration: 18s, 23s, 6s; 
  }

  /* 紫色光斑 */
  .blob-2 {
    width: 60vw; height: 60vw;
    --blob-color: rgba(49, 30, 79, 0.55);
    animation-duration: 22s, 17s, 5s;
  }

  /* 青绿色光斑 */
  .blob-3 {
    width: 42vw; height: 42vw;
    --blob-color: rgba(21, 59, 55, 0.5);
    animation-duration: 15s, 25s, 7s;
  }

  /* X轴水平游动 */
  @keyframes floatX {
    from { margin-left: calc(var(--range-x) * -1); }
    to { margin-left: var(--range-x); }
  }

  /* Y轴垂直游动 */
  @keyframes floatY {
    from { margin-top: calc(var(--range-y) * -1); }
    to { margin-top: var(--range-y); }
  }

  /* 增加一个轻微的呼吸缩放效果，更有生命力 */
  @keyframes breathe {
    0% { transform: translate(-50%, -50%) scale(0.95); opacity: 0.8; }
    100% { transform: translate(-50%, -50%) scale(1.05); opacity: 0.9; }
  }

  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 20%, rgba(0,0,0,0.25) 95%);
    pointer-events: none;
    z-index: 1;
  }
</style>

<script is:inline>
  let initialized = false;

  function randomizeBlobs() {
    if (initialized) return;
    initialized = true;

    const blobs = document.querySelectorAll('.glow-blob');
    
    blobs.forEach(blob => {
      // 获取元素的实际渲染尺寸（vw单位需要换算成px才能精确计算边界）
      const rect = blob.getBoundingClientRect();
      const blobRadius = Math.max(rect.width, rect.height) / 2;
      
      // 计算安全活动范围：屏幕一半减去光斑半径，再乘以 0.8 留出一点边距
      const maxMoveX = (window.innerWidth / 2 - blobRadius) * 0.8;
      const maxMoveY = (window.innerHeight / 2 - blobRadius) * 0.8;

      // 设置 CSS 变量，作为 margin 偏移的最大距离
      blob.style.setProperty('--range-x', `${Math.max(20, maxMoveX)}px`);
      blob.style.setProperty('--range-y', `${Math.max(20, maxMoveY)}px`);

      // 随机设定初始位置（保持在屏幕中间 60% 的区域内）
      const startTop = 20 + Math.random() * 60 + '%';
      const startLeft = 20 + Math.random() * 60 + '%';
      blob.style.top = startTop;
      blob.style.left = startLeft;
    });
  }

  // Astro 环境下的稳健监听
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    randomizeBlobs();
  } else {
    document.addEventListener('DOMContentLoaded', randomizeBlobs);
  }

  document.addEventListener('astro:after-swap', () => {
    initialized = false;
    randomizeBlobs();
  });
  
  // 窗口大小改变时重新计算边界，防止出现滚动条
  window.addEventListener('resize', () => {
     initialized = false;
     randomizeBlobs();
  });
</script>