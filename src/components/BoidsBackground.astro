<div class="fluid-background">
  <div class="glow-blob blob-1"></div>
  <div class="glow-blob blob-2"></div>
  <div class="glow-blob blob-3"></div>
  <div class="vignette"></div>
</div>

<style>

  .fluid-background {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: var(--background);
    overflow: hidden;
  }

  .glow-blob {
    position: absolute;
    border-radius: 50%;
    z-index: 0;
    transform: translate(-50%, -50%);
    /* 核心优化1：增加极大的高斯模糊，让光斑彻底晕开 */
    filter: blur(80px); 
    /* 核心优化2：渐变范围扩大到70%，让中心发光区更大 */
    background: radial-gradient(circle, var(--blob-color) 0%, transparent 70%);
    opacity: 1; /* 整体不透明度拉满，亮度全靠颜色里的透明度控制 */
    animation-name: floatX, floatY, breathe; 
    animation-iteration-count: infinite, infinite, infinite;
    animation-direction: alternate, alternate, alternate;
    animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* 蓝色光斑 - 尺寸加大，颜色加深 */
  .blob-1 {
    width: 120vw; height: 120vw;
    /* 透明度从 0.6 提升到 0.85 */
    --blob-color: var(--blob-1);
    animation-duration: 18s, 23s, 6s; 
  }

  /* 紫色光斑 - 尺寸加大，颜色加深 */
  .blob-2 {
    width: 90vw; height: 90vw;
    /* 透明度从 0.55 提升到 0.8 */
    --blob-color: var(--blob-2);
    animation-duration: 22s, 17s, 5s;
  }

  /* 青绿色光斑 - 尺寸加大，颜色加深 */
  .blob-3 {
    width: 70vw; height: 70vw;
    /* 透明度从 0.5 提升到 0.75 */
    --blob-color: var(--blob-3);
    animation-duration: 15s, 25s, 7s;
  }

  @keyframes floatX {
    from { margin-left: calc(var(--range-x) * -1); }
    to { margin-left: var(--range-x); }
  }

  @keyframes floatY {
    from { margin-top: calc(var(--range-y) * -1); }
    to { margin-top: var(--range-y); }
  }

  @keyframes breathe {
    0% { transform: translate(-50%, -50%) scale(0.95); opacity: 0.9; }
    100% { transform: translate(-50%, -50%) scale(1.05); opacity: 1; }
  }

  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 20%, var(--vignette-color) 95%);
    pointer-events: none;
    z-index: 1;
  }
</style>

<script is:inline>
  let initialized = false;

  function randomizeBlobs() {
    if (initialized) return;
    initialized = true;

    const blobs = document.querySelectorAll('.glow-blob');
    
    blobs.forEach(blob => {
      // 获取元素的实际渲染尺寸（vw单位需要换算成px才能精确计算边界）
      const rect = blob.getBoundingClientRect();
      const blobRadius = Math.max(rect.width, rect.height) / 2;
      
      // 计算安全活动范围：屏幕一半减去光斑半径，再乘以 0.8 留出一点边距
      const maxMoveX = (window.innerWidth / 2 - blobRadius) * 0.8;
      const maxMoveY = (window.innerHeight / 2 - blobRadius) * 0.8;

      // 设置 CSS 变量，作为 margin 偏移的最大距离
      blob.style.setProperty('--range-x', `${Math.max(20, maxMoveX)}px`);
      blob.style.setProperty('--range-y', `${Math.max(20, maxMoveY)}px`);

      // 随机设定初始位置（保持在屏幕中间 60% 的区域内）
      const startTop = 20 + Math.random() * 60 + '%';
      const startLeft = 20 + Math.random() * 60 + '%';
      blob.style.top = startTop;
      blob.style.left = startLeft;
    });
  }

  // Astro 环境下的稳健监听
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    randomizeBlobs();
  } else {
    document.addEventListener('DOMContentLoaded', randomizeBlobs);
  }

  document.addEventListener('astro:after-swap', () => {
    initialized = false;
    randomizeBlobs();
  });
  
  // 窗口大小改变时重新计算边界，防止出现滚动条
  window.addEventListener('resize', () => {
     initialized = false;
     randomizeBlobs();
  });
</script>