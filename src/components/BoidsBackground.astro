---
// CSS 流动光晕背景组件
---

<div class="fluid-background">
  <div class="glow-blob blob-1"></div>
  <div class="glow-blob blob-2"></div>
  <div class="glow-blob blob-3"></div>
  <div class="vignette"></div>
</div>

<style>
  @import "../styles/global.scss";

  .fluid-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
    background: var(--background);
    overflow: hidden;
  }

  /* 光斑公用样式 */
  .glow-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);        /* 加大模糊半径，独立产生柔光效果 */
    opacity: 0;
    z-index: 0;
    will-change: transform;
    transform: translate(-50%, -50%);
    transition: opacity 0.5s ease;
    mix-blend-mode: screen;    /* 让光斑叠加更柔和，类似之前的背景模糊混合感 */
  }

  /* 蓝色光斑 */
  .blob-1 {
    width: 60vw;
    height: 60vw;
    background: rgba(31, 52, 86, 0.7);
    top: var(--start-top);
    left: var(--start-left);
    animation: float-generic 11s ease-in-out infinite alternate;
    animation-delay: var(--delay);
  }

  /* 紫色光斑 */
  .blob-2 {
    width: 50vw;
    height: 50vw;
    background: rgba(49, 30, 79, 0.65);
    top: var(--start-top);
    left: var(--start-left);
    animation: float-generic 7s ease-in-out infinite alternate;
    animation-delay: var(--delay);
  }

  /* 青绿色光斑 */
  .blob-3 {
    width: 45vw;
    height: 45vw;
    background: rgba(21, 59, 55, 0.6);
    top: var(--start-top);
    left: var(--start-left);
    animation: float-generic 5s ease-in-out infinite alternate;
    animation-delay: var(--delay);
  }

  /* 柔光遮罩：模拟原 backdrop-filter 产生的整体雾化感 */
  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 30%, rgba(0,0,0,0.2) 90%);
    backdrop-filter: blur(20px);  /* 轻量级模糊，即使偶尔失效也不影响主体 */
    -webkit-backdrop-filter: blur(20px);
    pointer-events: none;
    z-index: 1;
  }

  @keyframes float-generic {
    0% {
      transform: translate(-50%, -50%) scale(1);
    }
    100% {
      transform: translate(calc(-50% + var(--move-x)), calc(-50% + var(--move-y))) scale(1.15);
    }
  }
</style>

<script is:inline>
  function randomizeBlobs() {
    const blobs = document.querySelectorAll('.glow-blob');
    blobs.forEach(blob => {
      blob.style.opacity = '0';

      const startTop = 10 + Math.random() * 80;
      const startLeft = 10 + Math.random() * 80;
      const moveX = (Math.random() - 0.5) * 80 + 'vw';
      const moveY = (Math.random() - 0.5) * 80 + 'vh';
      const delay = Math.random() * 1 + 's';

      blob.style.setProperty('--start-top', `${startTop}%`);
      blob.style.setProperty('--start-left', `${startLeft}%`);
      blob.style.setProperty('--move-x', moveX);
      blob.style.setProperty('--move-y', moveY);
      blob.style.setProperty('--delay', delay);

      setTimeout(() => {
        blob.style.opacity = '0.85';
      }, 50);
    });
  }

  document.addEventListener('astro:after-swap', randomizeBlobs);
  document.addEventListener('DOMContentLoaded', randomizeBlobs);
</script>