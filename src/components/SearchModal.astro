---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const searchData = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description.replace(/<[^>]+>/g, ''),
  dir1: post.data.dir1 ?? '',
  dir2: post.data.dir2 ?? '',
  slug: post.id,
}));
---

<script define:vars={{ searchData }}>
  window.__SEARCH_DATA__ = searchData;
</script>

<dialog id="search-modal" class="search-modal" aria-label="搜索文章">
  <div class="search-modal-content">
    <div class="search-input-wrapper">
      <svg class="search-input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.3-4.3"/>
      </svg>
      <input
        type="text"
        id="search-input"
        class="search-input"
        placeholder="搜索文章..."
        autocomplete="off"
        aria-label="搜索文章"
      />
      <button id="search-close-btn" class="search-close-btn" aria-label="关闭搜索" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
    </div>
    <ul id="search-results" class="search-results" role="listbox" aria-label="搜索结果">
    </ul>
  </div>
</dialog>

<script src="../scripts/search"></script>

<style>
  .search-modal {
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 0;
    max-width: 600px;
    width: 90vw;
    color: var(--foreground);
    animation: search-modal-in 0.15s ease-out;
  }

  .search-modal::backdrop {
    background: rgba(0, 0, 10, 0.8);
    backdrop-filter: blur(4px);
    animation: search-backdrop-in 0.15s ease-out;
  }

  @keyframes search-modal-in {
    from {
      opacity: 0;
      transform: translateY(-12px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes search-backdrop-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .search-modal-content {
    display: flex;
    flex-direction: column;
    max-height: 70vh;
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--background);
    border-radius: 16px 16px 0 0;
  }

  .search-input-icon {
    color: var(--foreground-dark);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--foreground);
    font-size: 1.1rem;
    outline: none;
    font-family: inherit;
  }

  .search-input::placeholder {
    color: var(--foreground-dark);
  }

  .search-close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--foreground-dark);
    cursor: pointer;
    padding: 4px;
    border-radius: 8px;
    flex-shrink: 0;
    transition: all 0.15s ease;
  }

  .search-close-btn:hover {
    color: var(--foreground);
    background: var(--background-light);
  }

  .search-results {
    list-style: none;
    padding: 0.5rem 0;
    margin: 0;
    overflow-y: auto;
    max-height: 400px;
  }

  .search-result-item {
    border-left: 3px solid transparent;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .search-result-item:hover,
  .search-result-item.selected {
    border-left-color: var(--accent);
    background: var(--background-light);
  }

  .search-result-link {
    display: block;
    padding: 0.75rem 1.25rem;
    text-decoration: none;
    color: inherit;
  }

  .search-result-title {
    display: block;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--foreground);
    margin-bottom: 0.25rem;
  }

  .search-result-category {
    display: inline-block;
    font-size: 0.75rem;
    color: var(--accent-light);
    background: rgba(97, 123, 255, 0.15);
    padding: 2px 8px;
    border-radius: 999px;
    margin-bottom: 0.25rem;
  }

  .search-result-desc {
    display: block;
    font-size: 0.85rem;
    color: var(--foreground-dark);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .search-no-results {
    padding: 2.5rem 1.25rem;
    text-align: center;
    color: var(--foreground-dark);
    font-size: 0.95rem;
  }

  /* Scrollbar */
  .search-results::-webkit-scrollbar {
    width: 4px;
  }

  .search-results::-webkit-scrollbar-track {
    background: transparent;
  }

  .search-results::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 4px;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .search-modal {
      max-width: none;
      width: 95vw;
      margin-top: 6vh;
      align-self: flex-start;
    }

    .search-modal-content {
      max-height: 65vh;
    }

    .search-input {
      font-size: 16px; /* Prevent iOS zoom */
    }

    .search-input-wrapper {
      padding: 0.75rem 1rem;
    }
  }
</style>
