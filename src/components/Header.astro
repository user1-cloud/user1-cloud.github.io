---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import HeaderSocialLinks from '../components/HeaderSocialLinks.astro'
import Icon from './Icon.astro';
---

<header>
	<nav>
		<h2><HeaderLink href="/">{SITE_TITLE}</HeaderLink></h2>
		<div class="internal-links">
			<HeaderLink href="/">主页</HeaderLink>
			<HeaderLink href="/blog">博客</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>

		<div id="header-actions">
			<div class="theme-selector">
				<button id="theme-switcher-btn" class="theme-switcher-btn"
					aria-label="切换主题" title="切换配色方案" type="button">
					<Icon name="theme" />
				</button>
				<div id="theme-dropdown" class="theme-dropdown" hidden>
					<div data-theme="dark-blue"><span class="theme-dot" style="background:#4a65e8"></span>深蓝</div>
					<div data-theme="dark-green"><span class="theme-dot" style="background:#10b981"></span>深绿</div>
					<div data-theme="dark-purple"><span class="theme-dot" style="background:#8b5cf6"></span>深紫</div>
					<div data-theme="light-blue"><span class="theme-dot" style="background:#4565d8"></span>亮蓝</div>
					<div data-theme="light-green"><span class="theme-dot" style="background:#2e9a6a"></span>亮绿</div>
					<div data-theme="light-rose"><span class="theme-dot" style="background:#d1476e"></span>亮玫瑰</div>
				</div>
			</div>
			<button id="search-trigger-btn" class="search-trigger-btn"
				aria-label="搜索文章 (Ctrl+K)" title="搜索 (Ctrl+K)" type="button">
				<Icon name="search" />
				<span class="search-kbd-hint">Ctrl+K</span>
			</button>
			<div id="header-social">
				<HeaderSocialLinks/>
			</div>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 6px;
		background: transparent;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		position: relative;
	}
	.internal-links {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 0.5rem;
		white-space: nowrap;
	}

	#header-actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.theme-selector {
		position: relative;
	}

	.theme-switcher-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 8px;
		color: var(--foreground-dark);
		cursor: pointer;
		font-family: inherit;
		transition: all 0.2s ease;
	}

	.theme-switcher-btn:hover {
		border-color: var(--accent);
		color: var(--foreground);
	}

	.theme-dropdown {
		position: absolute;
		top: calc(100% + 6px);
		right: 0;
		z-index: 100;
		background: var(--background-dark);
		border: 1px solid var(--border);
		border-radius: 8px;
		box-shadow: var(--box-shadow);
		padding: 4px;
		min-width: 120px;
	}

	.theme-dropdown > div {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 6px 10px;
		border-radius: 6px;
		cursor: pointer;
		font-size: 0.88rem;
		color: var(--foreground);
		transition: background 0.15s ease;
		white-space: nowrap;
	}

	.theme-dropdown > div:hover {
		background: var(--muted);
	}

	.theme-dropdown > div.current {
		background: var(--muted);
		font-weight: 600;
	}

	.theme-dot {
		display: inline-block;
		width: 10px;
		height: 10px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	.search-trigger-btn {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 4px 10px;
		color: var(--foreground-dark);
		cursor: pointer;
		font-size: 0.85rem;
		font-family: inherit;
		transition: all 0.2s ease;
		white-space: nowrap;
	}

	.search-trigger-btn:hover {
		border-color: var(--accent);
		color: var(--foreground);
	}

	.search-kbd-hint {
		font-size: 0.7rem;
		color: var(--foreground-dark);
		opacity: 0.6;
	}

	@media (max-width: 640px) {
		.search-kbd-hint {
			display: none;
		}
	}

	@media (max-width: 768px) {
		#header-social {
			display: none;
		}
	}
</style>

<script>
  (function() {
    if (window.__themeScriptLoaded) return;
    window.__themeScriptLoaded = true;

    const THEMES = ['dark-blue', 'dark-green', 'dark-purple', 'light-blue', 'light-green', 'light-rose'];
    const STORAGE_KEY = 'blog-theme';

    function getSavedTheme() {
      try {
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved && THEMES.includes(saved)) return saved;
      } catch (e) {}
      return null;
    }

    function getSystemPreference() {
      return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light-blue' : 'dark-blue';
    }

    function getEffectiveTheme() {
      return getSavedTheme() || getSystemPreference();
    }

    function applyTheme(name) {
      document.documentElement.setAttribute('data-theme', name);
      markCurrent(name);
    }

    function markCurrent(name) {
      const dropdown = document.getElementById('theme-dropdown');
      if (!dropdown) return;
      dropdown.querySelectorAll('div[data-theme]').forEach(el => {
        el.classList.toggle('current', el.dataset.theme === name);
      });
    }

    function showDropdown() {
      const dropdown = document.getElementById('theme-dropdown');
      if (dropdown) {
        markCurrent(getEffectiveTheme());
        dropdown.hidden = false;
      }
    }

    function hideDropdown() {
      const dropdown = document.getElementById('theme-dropdown');
      if (dropdown) dropdown.hidden = true;
    }

    function selectTheme(name) {
      try { localStorage.setItem(STORAGE_KEY, name); } catch (e) {}
      applyTheme(name);
    }

    // 使用事件委托 — 兼容 Astro 视图过渡中 DOM 可能被替换的情况
    document.addEventListener('click', (e) => {
      const btn = document.getElementById('theme-switcher-btn');
      const dropdown = document.getElementById('theme-dropdown');
      if (!btn || !dropdown) return;

      // 点击主题按钮 → 切换下拉栏
      if (btn.contains(e.target)) {
        if (dropdown.hidden) showDropdown();
        else hideDropdown();
        return;
      }

      // 下拉栏已关闭，无需处理
      if (dropdown.hidden) return;

      // 点击下拉栏中的选项
      const option = e.target.closest('div[data-theme]');
      if (option && dropdown.contains(option)) {
        selectTheme(option.dataset.theme);
        return;
      }

      // 点击下拉栏外部 → 关闭
      if (!dropdown.contains(e.target)) {
        hideDropdown();
      }
    });

    // 初始应用主题
    applyTheme(getEffectiveTheme());

    // 视图过渡后重新同步主题状态
    document.addEventListener('astro:page-load', () => {
      applyTheme(getEffectiveTheme());
    });
  })();
</script>
