---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import HeaderSocialLinks from './HeaderSocialLinks.astro'
---

<header>
	<nav>
		<h2><HeaderLink href="/">{SITE_TITLE}</HeaderLink></h2>
		<div class="internal-links">
			<HeaderLink href="/">主页</HeaderLink>
			<HeaderLink href="/blog">博客</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>

		<div id="header-actions">
			<div id="header-social">
				<HeaderSocialLinks/>
			</div>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 6px;
		background: transparent;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		position: relative;
	}
	.internal-links {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 0.5rem;
		white-space: nowrap;
	}

	#header-actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	@media (max-width: 768px) {
		#header-social {
			display: none;
		}
	}
</style>
