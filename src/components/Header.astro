---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import HeaderSocialLinks from '../components/HeaderSocialLinks.astro'
import Icon from './Icon.astro';
---

<header>
	<nav>
		<h2><HeaderLink href="/">{SITE_TITLE}</HeaderLink></h2>
		<div class="internal-links">
			<HeaderLink href="/">主页</HeaderLink>
			<HeaderLink href="/blog">博客</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>

		<div id="header-actions">
			<button id="theme-switcher-btn" class="theme-switcher-btn"
				aria-label="切换主题" title="切换配色方案" type="button">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/>
				</svg>
			</button>
			<button id="search-trigger-btn" class="search-trigger-btn"
				aria-label="搜索文章 (Ctrl+K)" title="搜索 (Ctrl+K)" type="button">
				<Icon name="search" />
				<span class="search-kbd-hint">Ctrl+K</span>
			</button>
			<div id="header-social">
				<HeaderSocialLinks/>
			</div>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 6px;
		background: transparent;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		position: relative;
	}
	.internal-links {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 0.5rem;
		white-space: nowrap;
	}

	#header-actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.theme-switcher-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 4px 8px;
		color: var(--foreground-dark);
		cursor: pointer;
		font-family: inherit;
		transition: all 0.2s ease;
	}

	.theme-switcher-btn:hover {
		border-color: var(--accent);
		color: var(--foreground);
	}

	.search-trigger-btn {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 4px 10px;
		color: var(--foreground-dark);
		cursor: pointer;
		font-size: 0.85rem;
		font-family: inherit;
		transition: all 0.2s ease;
		white-space: nowrap;
	}

	.search-trigger-btn:hover {
		border-color: var(--accent);
		color: var(--foreground);
	}

	.search-kbd-hint {
		font-size: 0.7rem;
		color: var(--foreground-dark);
		opacity: 0.6;
	}

	@media (max-width: 640px) {
		.search-kbd-hint {
			display: none;
		}
	}

	/* 使用 id 选择器 #header-social */
	@media (max-width: 768px) {
		#header-social {
			display: none;
		}
	}
</style>

<script>
  const THEMES = ['dark-blue', 'dark-green', 'dark-purple', 'light-blue', 'light-green', 'light-rose'];
  const STORAGE_KEY = 'blog-theme';

  function getSavedTheme() {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved && THEMES.includes(saved)) return saved;
    } catch (e) {}
    return 'dark-blue';
  }

  function applyTheme(name) {
    document.documentElement.setAttribute('data-theme', name);
    // 同步 expressive-code 语法高亮主题
    document.querySelectorAll('.expressive-code').forEach(el => {
      if (name.startsWith('light-')) {
        el.setAttribute('data-theme', 'github-light');
      } else {
        el.removeAttribute('data-theme');
      }
    });
  }

  function cycleTheme() {
    const current = getSavedTheme();
    const idx = THEMES.indexOf(current);
    const next = THEMES[(idx + 1) % THEMES.length];
    try { localStorage.setItem(STORAGE_KEY, next); } catch (e) {}
    applyTheme(next);
  }

  // 页面加载时应用保存的主题
  applyTheme(getSavedTheme());

  // 绑定按钮
  document.addEventListener('astro:page-load', () => {
    applyTheme(getSavedTheme());
    const btn = document.getElementById('theme-switcher-btn');
    if (btn) {
      btn.removeEventListener('click', cycleTheme);
      btn.addEventListener('click', cycleTheme);
    }
  });

  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('theme-switcher-btn');
    if (btn) btn.addEventListener('click', cycleTheme);
  });
</script>