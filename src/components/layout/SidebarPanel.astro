---
// 可折叠侧栏共用包装组件
// 提供：aside 结构、折叠按钮、覆盖层背景
// 初始状态同步由 BaseHead.astro 在 <head> 中同步完成（避免 FOUC）
// 视图过渡后状态同步由 sidebar-tree.ts / sidebar-collapse.ts 处理
interface Props {
  position: 'left' | 'right';
  sidebarId: string;
  btnId: string;
  hasOverlay?: boolean;
  btnLabel?: string;
}

const {
  position,
  sidebarId,
  btnId,
  hasOverlay = false,
  btnLabel = '切换侧栏',
} = Astro.props;
---

<!-- 移动端覆盖层背景 -->
{hasOverlay && <div class={`${position}-sidebar-overlay-backdrop`}></div>}

<aside class={`${position}-sidebar sidebar-panel`} id={sidebarId}>
  <slot />
</aside>

<button class={`toggle-${position}-sidebar-btn sidebar-toggle-btn`} id={btnId} aria-label={btnLabel}>
  <span class="arrow-icon"></span>
</button>
