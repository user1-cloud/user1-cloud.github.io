---
import { DIR1_ORDER, DIR2_ORDER } from '../../consts';
import SidebarShell from './SidebarShell.astro';

interface SidebarPost {
  title: string;
  slug: string;
  pubDate: Date;
  dir1: string;
  dir2: string;
  tags: string[];
}

const { posts, currentSlug } = Astro.props as { posts: SidebarPost[]; currentSlug: string };
  const currentPost = posts.find(p => p.slug === currentSlug);
  const currentDir1 = currentPost?.dir1 || '';
  const currentDir2 = currentPost?.dir2 || '';
  const currentTags: string[] = currentPost?.tags || [];

// 全部文章按 pubDate 降序
const sorted = [...posts].sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());

// dir1/dir2 显示顺序使用共享常量 DIR1_ORDER / DIR2_ORDER（来自 ../consts）

// --- 目录树 ---
// 按 dir1 分组，每组内按 dir2 分组，组内按日期降序
const dirTree = new Map<string, Map<string, SidebarPost[]>>();
for (const post of sorted) {
  const d1 = post.dir1 || '未分类';
  const d2 = post.dir2 || '';
  if (!dirTree.has(d1)) dirTree.set(d1, new Map());
  const d2Map = dirTree.get(d1)!;
  if (!d2Map.has(d2)) d2Map.set(d2, []);
  d2Map.get(d2)!.push(post);
}

const orderedDir1 = [
  ...DIR1_ORDER.filter(d => dirTree.has(d)),
  ...[...dirTree.keys()].filter(d => !DIR1_ORDER.includes(d)),
];

// --- 标签树 ---
// 按标签分组，标签按文章数量降序，组内按日期降序
const tagTree = new Map<string, SidebarPost[]>();
for (const post of sorted) {
  for (const tag of post.tags) {
    if (!tagTree.has(tag)) tagTree.set(tag, []);
    tagTree.get(tag)!.push(post);
  }
}
const orderedTags = [...tagTree.entries()].sort((a, b) => b[1].length - a[1].length);
---

<SidebarShell
  position="left"
  sidebarId="leftSidebar"
  hasOverlay={true}
>
  <div class="sidebar-inner">
    <!-- 工具栏：搜索 + 主题（横向布局） -->
    <div class="ls-toolbar">
      <button id="search-trigger-btn" class="ls-tool-btn"
        aria-label="搜索文章 (Ctrl+K)" title="搜索 (Ctrl+K)" type="button">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span>搜索</span>
        <span class="search-kbd-hint">Ctrl+K</span>
      </button>

      <div class="ls-tool-btn-wrap">
        <button id="theme-switcher-btn" class="ls-tool-btn"
          aria-label="切换主题" title="切换配色方案" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
          <span>主题</span>
        </button>
        <div id="theme-dropdown" class="ls-theme-dropdown" hidden>
          <div data-theme="dark-blue"><span class="theme-dot" style="background:#4a65e8"></span>深蓝</div>
          <div data-theme="dark-green"><span class="theme-dot" style="background:#10b981"></span>深绿</div>
          <div data-theme="dark-purple"><span class="theme-dot" style="background:#8b5cf6"></span>深紫</div>
          <div data-theme="light-blue"><span class="theme-dot" style="background:#4565d8"></span>亮蓝</div>
          <div data-theme="light-green"><span class="theme-dot" style="background:#2e9a6a"></span>亮绿</div>
          <div data-theme="light-rose"><span class="theme-dot" style="background:#d1476e"></span>亮玫瑰</div>
        </div>
      </div>
    </div>
    <!-- 模式切换 -->
    <div class="ls-mode-toggle">
      <button id="ls-mode-dir" class="active" data-mode="directory">目录结构</button>
      <button id="ls-mode-tag" data-mode="tag">标签分类</button>
    </div>

    <!-- 位置指示器 -->
    <div class="position-indicator" id="ls-position-indicator"></div>

    <!-- 目录树 -->
    <ul class="ls-tree" id="ls-tree-dir" data-mode="directory">
      {orderedDir1.map(d1 => {
        const d2Map = dirTree.get(d1)!;
        const totalCount = [...d2Map.values()].reduce((s, a) => s + a.length, 0);
        const orderedD2 = [...d2Map.keys()].sort((a, b) => {
          const order = DIR2_ORDER[d1] || [];
          const ia = order.indexOf(a), ib = order.indexOf(b);
          if (ia !== -1 && ib !== -1) return ia - ib;
          if (ia !== -1) return -1;
          if (ib !== -1) return 1;
          return a.localeCompare(b);
        });
        const isCurrentDir1 = d1 === currentDir1;
        return (
          <li class:list={["tree-node", isCurrentDir1 && "has-current"]}>
            <div class:list={["node-header", { expanded: isCurrentDir1 }]}>
              <span class="node-arrow"></span>
              <span class="node-label">{d1}</span>
              <span class="node-count">{totalCount}</span>
            </div>
            <ul class:list={["node-children", { collapsed: !isCurrentDir1 }, isCurrentDir1 && "active-path"]}>
              {orderedD2.map(d2 => {
                const articles = d2Map.get(d2)!;
                const isCurrentDir2 = isCurrentDir1 && d2 === currentDir2;
                return (
                  <li class:list={["tree-node", isCurrentDir2 && "has-current"]}>
                    {d2 && (
                      <div class:list={["node-header", { expanded: isCurrentDir2 }]}>
                        <span class="node-arrow"></span>
                        <span class="node-label">{d2}</span>
                        <span class="node-count">{articles.length}</span>
                      </div>
                    )}
                    <ul class:list={["node-children", { collapsed: !!d2 && !isCurrentDir2 }, isCurrentDir2 && "active-path"]}>
                      {articles.map(article => (
                        <li class="article-item">
                          <a href={`/blog/${article.slug}/`} data-slug={article.slug}
                            class:list={[article.slug === currentSlug && "current"]}>
                            {article.title}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </li>
                );
              })}
            </ul>
          </li>
        );
      })}
    </ul>

    <!-- 标签树 -->
    <ul class="ls-tree" id="ls-tree-tag" data-mode="tag" hidden>
      {orderedTags.map(([tag, articles]) => {
        const isCurrentTag = currentTags.includes(tag);
        return (
        <li class:list={["tree-node", isCurrentTag && "has-current"]}>
          <div class:list={["node-header", { expanded: isCurrentTag }]}>
            <span class="node-arrow"></span>
            <span class="node-label">{tag}</span>
            <span class="node-count">{articles.length}</span>
          </div>
          <ul class:list={["node-children", { collapsed: !isCurrentTag }]}>
            {articles.map(article => (
              <li class="article-item">
                <a href={`/blog/${article.slug}/`} data-slug={article.slug}
                  class:list={[article.slug === currentSlug && "current"]}>
                  {article.title}
                </a>
              </li>
            ))}
          </ul>
        </li>
        );
      })}
    </ul>
  </div>
</SidebarShell>

<script src="../../scripts/theme"></script>
