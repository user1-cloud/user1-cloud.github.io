---
// 可折叠侧栏共用包装组件
// 按钮已移至 BlogPost.astro 的 three-col-layout 间隙中
interface Props {
  position: 'left' | 'right';
  sidebarId: string;
  hasOverlay?: boolean;
}

const { position, sidebarId, hasOverlay = false } = Astro.props;
---

{hasOverlay && <div class={`${position}-sidebar-overlay-backdrop`}></div>}

<aside class={`${position}-sidebar sidebar-panel`} id={sidebarId}>
  <slot />
</aside>
