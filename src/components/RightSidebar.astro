---
import CollapsibleSidebar from './CollapsibleSidebar.astro';

const { description } = Astro.props as { description: string };
---

<CollapsibleSidebar
  position="right"
  sidebarId="rightSidebar"
  btnId="toggleSidebarBtn"
  storageKey="blog-sidebar-collapsed"
  collapsedClass="sidebar-collapsed"
  btnLabel="切换侧边栏"
>
  <div class="sidebar-inner">
    <!-- 上栏：目录区 -->
    <div class="toc-area">
      <div class="position-indicator"></div>
      <h3>目录</h3>
      <ul id="toc-list"></ul>
    </div>
    <hr/>
    <!-- 下栏：简介区 -->
    <div class="desc-area">
      <p set:html={description}></p>
    </div>
  </div>
</CollapsibleSidebar>

<script>
  // 右侧栏折叠切换与状态恢复
  const RS_STORAGE = 'blog-sidebar-collapsed';

  function restoreRightSidebar() {
    try {
      if (localStorage.getItem(RS_STORAGE) === 'true') {
        document.documentElement.classList.add('sidebar-collapsed');
      } else {
        document.documentElement.classList.remove('sidebar-collapsed');
      }
    } catch (_) {}
  }

  function _initRightSidebar() {
    const btn = document.getElementById('toggleSidebarBtn');
    if (!btn) return;

    function toggle() {
      document.documentElement.classList.toggle('sidebar-collapsed');
      const nowCollapsed = document.documentElement.classList.contains('sidebar-collapsed');
      localStorage.setItem(RS_STORAGE, nowCollapsed);
    }

    btn.removeEventListener('click', toggle);
    btn.addEventListener('click', toggle);
  }

  _initRightSidebar();
  restoreRightSidebar();
  document.addEventListener('astro:after-swap', () => {
    restoreRightSidebar(); // 同步恢复，避免视图过渡闪烁
    _initRightSidebar();
  });
  document.addEventListener('astro:page-load', restoreRightSidebar);
</script>
