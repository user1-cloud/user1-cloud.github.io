---
const { 
  bvid, 
  page = 1, 
  width = '100%', 
  height = '400px',
  autoplay = 0, 
  muted = 1
} = Astro.props;

const src = `https://player.bilibili.com/player.html?bvid=${bvid}&page=${page}&autoplay=${autoplay}&muted=${muted}`;
---

<div class="fade-in-on-scroll">
<iframe
  src={src}
  allowfullscreen
  width={width}
  height={height}
  loading="lazy"
  title="B站视频"
  style={{ 
    maxWidth: '100%',
    border: 'none', // 用 CSS 代替旧的 border 属性
    borderRadius: '8px' // 可选：加一点圆角更美观
  }}
></iframe>
</div>