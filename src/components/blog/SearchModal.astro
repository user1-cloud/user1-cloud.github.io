---
import { getSearchData } from '../../lib/blogData';
import Icon from '../ui/Icon.astro';

const searchData = await getSearchData();
---

<script define:vars={{ searchData }}>
  window.__SEARCH_DATA__ = searchData;
</script>

<dialog id="search-modal" class="search-modal" aria-label="搜索文章">
  <div class="search-modal-content">
    <div class="search-input-wrapper">
      <span class="search-input-icon"><Icon name="search" /></span>
      <input
        type="text"
        id="search-input"
        class="search-input"
        placeholder="搜索文章..."
        autocomplete="off"
        aria-label="搜索文章"
      />
      <button id="search-close-btn" class="search-close-btn" aria-label="关闭搜索" type="button">
        <Icon name="close" />
      </button>
    </div>
    <ul id="search-results" class="search-results" role="listbox" aria-label="搜索结果">
    </ul>
  </div>
</dialog>

<script src="../../scripts/search"></script>

<style>
  .search-modal {
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 0;
    max-width: 600px;
    width: 90vw;
    color: var(--foreground);
    animation: search-modal-in 0.15s ease-out;
  }

  .search-modal::backdrop {
    background: rgba(var(--backdrop-rgb), 0.8);
    backdrop-filter: blur(4px);
    animation: search-backdrop-in 0.15s ease-out;
  }

  @keyframes search-modal-in {
    from {
      opacity: 0;
      transform: translateY(-12px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes search-backdrop-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .search-modal-content {
    display: flex;
    flex-direction: column;
    max-height: 70vh;
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--background);
    border-radius: 16px 16px 0 0;
  }

  .search-input-icon {
    color: var(--foreground-dark);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--foreground);
    font-size: 1.1rem;
    outline: none;
    font-family: inherit;
  }

  .search-input::placeholder {
    color: var(--foreground-dark);
  }

  .search-close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--foreground-dark);
    cursor: pointer;
    padding: 4px;
    border-radius: 8px;
    flex-shrink: 0;
    transition: all 0.15s ease;
  }

  .search-close-btn:hover {
    color: var(--foreground);
    background: var(--background-light);
  }

  .search-results {
    list-style: none;
    padding: 0.5rem 0;
    margin: 0;
    overflow-y: auto;
    max-height: 400px;
  }

  :global(.search-result-item) {
    border-left: 3px solid transparent;
    border-bottom: 1px solid var(--border);
    margin: 0;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  :global(.search-result-item:last-child) {
    border-bottom: none;
  }

  :global(.search-result-item:hover),
  :global(.search-result-item.selected) {
    border-left-color: var(--accent);
    background: var(--background-light);
  }

  :global(.search-result-link) {
    display: block;
    padding: 1.25rem 1.75rem;
    text-decoration: none;
    color: inherit;
  }

  :global(.search-result-title) {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--foreground);
    margin-bottom: 0.4rem;
    line-height: 1.5;
  }

  :global(.search-result-category) {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--accent);
    background: rgba(var(--accent-rgb), 0.12);
    padding: 2px 10px;
    border-radius: 999px;
    margin-bottom: 0.45rem;
    letter-spacing: 0.03em;
  }

  :global(.search-result-desc) {
    display: block;
    font-size: 0.8rem;
    color: var(--foreground-dark);
    opacity: 0.55;
    line-height: 1.6;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.search-highlight) {
    color: var(--accent-light);
    background: rgba(var(--accent-rgb), 0.2);
    border-radius: 2px;
    padding: 0 1px;
  }

  :global(.search-no-results) {
    padding: 3rem 1.75rem;
    text-align: center;
    color: var(--foreground-dark);
    font-size: 0.95rem;
  }

  /* Scrollbar */
  .search-results::-webkit-scrollbar {
    width: 4px;
  }

  .search-results::-webkit-scrollbar-track {
    background: transparent;
  }

  .search-results::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 4px;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .search-modal {
      max-width: none;
      width: 95vw;
      margin-top: 6vh;
      align-self: flex-start;
    }

    .search-modal-content {
      max-height: 65vh;
    }

    .search-input {
      font-size: 16px; /* Prevent iOS zoom */
    }

    .search-input-wrapper {
      padding: 0.75rem 1rem;
    }
  }
</style>
