---
interface Props {
  width?: string | number;
  height?: string | number;
  url?: string;
}

const { width = '100%', height = '600px', url: initialUrl = 'https://example.com' } = Astro.props;

// 验证URL，确保不是当前页面
const validateUrl = (url: string): string => {
  try {
    const currentUrl = new URL(Astro.url);
    const targetUrl = new URL(url);
    
    // 检查是否是当前页面
    if (targetUrl.origin === currentUrl.origin && targetUrl.pathname === currentUrl.pathname) {
      return 'https://example.com';
    }
    
    // 确保有协议
    if (!targetUrl.protocol.startsWith('http')) {
      return 'https://example.com';
    }
    
    return url;
  } catch (e) {
    return 'https://example.com';
  }
};

const safeUrl = initialUrl ? validateUrl(initialUrl) : 'https://example.com';
---

<div class="mini-browser" style={`width: ${width}; height: ${height};`}>
  <div class="browser-chrome">
    <div class="browser-controls">
      <div class="control-btn close"></div>
      <div class="control-btn minimize"></div>
      <div class="control-btn maximize"></div>
    </div>
    <div class="url-container">
      <input 
        type="text" 
        id="browser-url-input"
        class="url-input"
        value={safeUrl}
        placeholder="输入网址 (例如: https://example.com)"
      />
      <button class="go-btn" id="go-btn">前往</button>
    </div>
  </div>
  <div class="browser-content">
    <iframe 
      id="browser-frame"
      src={safeUrl}
      sandbox="allow-same-origin allow-scripts allow-popups allow-forms"
      frameborder="0"
      class="browser-frame"
    ></iframe>
  </div>
</div>

<style>
  .mini-browser {
    background-color: var(--browser-bg);
    border-radius: 8px;
    box-shadow: var(--browser-shadow);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    border: 1px solid var(--browser-border);
  }

  .browser-chrome {
    background: linear-gradient(to bottom, var(--browser-chrome-top), var(--browser-chrome-bottom));
    padding: 8px 16px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--browser-border);
    height: 48px;
  }

  .browser-controls {
    display: flex;
    gap: 8px;
    margin-right: 16px;
  }

  .control-btn {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .close {
    background-color: #ff5f57;
  }

  .minimize {
    background-color: #ffbd2e;
  }

  .maximize {
    background-color: #28c940;
  }

  .url-container {
    flex: 1;
    display: flex;
    gap: 8px;
    max-width: calc(100% - 120px);
  }

  .url-input {
    flex: 1;
    min-width: 300px;
    background: var(--browser-input-bg);
    border: 1px solid var(--browser-input-border);
    border-radius: 4px;
    color: var(--browser-text);
    padding: 8px 12px;
    font-size: 14px;
    outline: none;
    transition: border-color 0.3s;
  }

  .url-input:focus {
    border-color: var(--browser-accent);
    box-shadow: 0 0 0 2px rgba(var(--browser-accent-rgb), 0.3);
  }

  .url-input::placeholder {
    color: var(--browser-placeholder);
  }

  .go-btn {
    background: var(--browser-accent);
    color: var(--browser-text);
    border: none;
    border-radius: 4px;
    padding: 8px 16px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .go-btn:hover {
    background: var(--browser-accent-hover);
    transform: translateY(-1px);
  }

  .go-btn:active {
    transform: translateY(0);
  }

  .browser-content {
    flex: 1;
    overflow: hidden;
  }

  .browser-frame {
    width: 100%;
    height: 100%;
    background-color: var(--browser-frame-bg);
    border: none;
  }

  /* 响应式设计 */
  @media (max-width: 768px) {
    .url-input {
      min-width: 200px;
    }
    .url-container {
      max-width: calc(100% - 80px);
    }
  }

  @media (max-width: 480px) {
    .browser-controls {
      display: none;
    }
    .url-input {
      min-width: 150px;
    }
    .url-container {
      max-width: 100%;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const urlInput = document.getElementById('browser-url-input');
    const goBtn = document.getElementById('go-btn');
    const iframe = document.getElementById('browser-frame');

    // 获取当前页面URL用于验证
    const currentUrl = new URL(window.location.href);
    const currentOrigin = currentUrl.origin;
    const currentPathname = currentUrl.pathname;

    const navigateToUrl = () => {
      let url = urlInput.value.trim();
      
      if (!url) return;
      
      // 添加协议如果不存在
      if (!url.startsWith('http://') && !url.startsWith('https://')) {
        url = 'https://' + url;
      }
      
      try {
        const targetUrl = new URL(url);
        
        // 验证不是当前页面
        if (targetUrl.origin === currentOrigin && targetUrl.pathname === currentPathname) {
          alert('不能加载当前页面，请输入其他网址');
          return;
        }
        
        // 检查是否是有效的HTTP/HTTPS URL
        if (!targetUrl.protocol.startsWith('http')) {
          alert('只支持HTTP和HTTPS协议');
          return;
        }
        
        iframe.src = url;
        urlInput.value = url; // 更新输入框显示
      } catch (e) {
        alert('无效的URL格式，请检查后重试');
      }
    };

    // 绑定按钮点击事件
    goBtn.addEventListener('click', navigateToUrl);
    
    // 支持回车键
    urlInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        navigateToUrl();
      }
    });
    
    // iframe加载完成后更新URL输入框
    iframe.addEventListener('load', () => {
      try {
        const currentFrameUrl = iframe.contentWindow.location.href;
        if (currentFrameUrl !== 'about:blank') {
          urlInput.value = currentFrameUrl;
        }
      } catch (e) {
        // 跨域错误，无法获取iframe URL
      }
    });
    
    // 处理iframe错误
    iframe.addEventListener('error', () => {
      alert('页面加载失败，请检查URL是否正确');
    });
  });
</script>