---
interface Props {
  hint?: string;
}

const { hint = '' } = Astro.props;
---

<div class="spoiler-wrapper">
  <div class="spoiler-overlay">
    <svg class="spoiler-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
      <circle cx="12" cy="12" r="3"/>
    </svg>
    <span class="spoiler-hint">{hint}</span>
  </div>
  <div class="spoiler-content">
    &nbsp
    <slot />
  </div>
</div>

<style>
  .spoiler-wrapper {
    display: inline-block;
    position: relative;
    border-radius: 8px;
    cursor: pointer;
    vertical-align: baseline;
  }

  .spoiler-content {
    filter: blur(8px);
    transition: filter 0.35s ease;
    user-select: none;
  }

  .spoiler-wrapper:hover .spoiler-content {
    filter: blur(0);
  }

  .spoiler-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    z-index: 1;
    pointer-events: none;
    transition: opacity 0.35s ease;
    color: var(--fg-muted, #888);
    background: transparent;
  }

  .spoiler-wrapper:hover .spoiler-overlay {
    opacity: 0;
  }

  .spoiler-icon {
    width: 32px;
    height: 32px;
    opacity: 0.6;
  }

  .spoiler-hint {
    font-size: 0.9rem;
    font-weight: 500;
    opacity: 0.7;
  }
</style>
