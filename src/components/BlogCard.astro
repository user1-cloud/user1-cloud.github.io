---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';

type BlogPost = CollectionEntry<'blog'>;

interface Props {
  post: BlogPost;
  level?: 3 | 4;
}

const { post, level = 3 } = Astro.props;
---

<style lang="scss">
@use '../styles/global.scss' as *; 

.blog-card {
    @include link-underline;
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.3s ease;
    cursor: pointer;
    display: block;
    width: 100%;
}

.blog-card:hover {
    transform: translateY(-4px);
}

.card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
}

.card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
}

.card-content {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.card-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
}

.card-description {
    font-size: 0.85rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    opacity: 0.8;
}

.card-date {
    font-size: 0.75rem;
    opacity: 0.6;
}
</style>

<article class="blog-card fade-in-on-scroll">
  <a href={`/blog/${post.id}/`} class="card-link">
    {post.data.heroImage && (
      <Image
        class="card-image"
        width={600}
        height={338}
        src={post.data.heroImage}
        alt={post.data.title}
      />
    )}
    <div class="card-content">
      {level === 4 ? (
        <h4 class="card-title">{post.data.title}</h4>
      ) : (
        <h3 class="card-title">{post.data.title}</h3>
      )}
      <p class="card-description">{post.data.description.replace(/<[^>]+>/g, '')}</p>
      <p class="card-date">
        <FormattedDate date={post.data.pubDate} />
      </p>
    </div>
  </a>
</article>