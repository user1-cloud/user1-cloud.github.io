---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';

type BlogPost = CollectionEntry<'blog'>;

interface Props {
  post: BlogPost;
  level?: 3 | 4;
}

const { post, level = 3 } = Astro.props;

// 生成随机柔和渐变
function getRandomGradient() {
  const h = Math.floor(Math.random() * 360);
  return `linear-gradient(135deg, hsl(${h}, 35%, 24%), hsl(${h}, 30%, 16%))`;
}

const cardGradient = getRandomGradient();
---

<style lang="scss">
@use '../styles/global.scss' as *; 
.card-grid {
    margin: 8px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: masonry;
    gap: 80px;
    list-style: none;
    padding: 0;
}

.blog-card {
    @include link-underline;
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease;
    cursor: pointer;
}

.blog-card:hover {
    transform: translateY(-6px);
}

.card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
}

.card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
}

.card-content {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
}

.card-title {
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.4;
}

.card-description {
    font-size: 0.95rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
}

.card-date {
    font-size: 0.85rem;
    margin-top: auto;
}

@media (max-width: 768px) {
    .card-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
}
</style>

<li class="fade-in-on-scroll">
  <article class="blog-card" style={`background: ${cardGradient}`}>
    <a href={`/blog/${post.id}/`} class="card-link">
      {post.data.heroImage && (
        <Image
          class="card-image"
          width={600}
          height={400}
          src={post.data.heroImage}
          alt={post.data.title}
        />
      )}

      <div class="card-content">
        {level === 4 ? (
          <h4 class="card-title">{post.data.title}</h4>
        ) : (
          <h3 class="card-title">{post.data.title}</h3>
        )}
        <p class="card-description">{post.data.description.replace(/<[^>]+>/g, '')}</p>
        <p class="card-date">
          <FormattedDate date={post.data.pubDate} />
        </p>
      </div>
    </a>
  </article>
</li>