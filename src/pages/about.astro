---
import { AVATAR_URL, EMAIL_QQ, EMAIL_OUTLOOK, GITHUB_USERNAME,
	GITHUB_PAGES_URL, CLOUDFLARE_PAGES_URL } from '../consts';
import Layout from '../layouts/BlogPost.astro';
import JsonLd from '../components/blog/JsonLd.astro';
import ReadmeContent from '../../README.md';

const aboutUrl = new URL('/about/', Astro.site).href;

const profilePageLd = {
	'@context': 'https://schema.org',
	'@type': 'ProfilePage',
	mainEntity: {
		'@type': 'Person',
		name: GITHUB_USERNAME,
		image: AVATAR_URL,
		url: aboutUrl,
		email: [EMAIL_QQ, EMAIL_OUTLOOK],
	},
};
---

<Layout
	title="关于"
	description="关于此项目"
	pubDate={new Date('April 23 2026')}
	heroImage={AVATAR_URL}
>
	<JsonLd slot="head" data={profilePageLd} />
	<h2>
		个人信息
	</h2>

	<h3>
		我是谁？
	</h3>

	<p>
		我是{GITHUB_USERNAME}
	</p>

	<h3>
		联系我
	</h3>

	<h4>
		邮箱
	</h4>

	<p>
		QQ邮箱：
	<a href={`mailto:${EMAIL_QQ}`} target="_blank">{EMAIL_QQ}</a>
	<br>
		Outlook：
	<a href={`mailto:${EMAIL_OUTLOOK}`} target="_blank">{EMAIL_OUTLOOK}</a>
	</p>

	<h2>本站链接</h2>
	<p>
	<a href={CLOUDFLARE_PAGES_URL} target="_blank">{CLOUDFLARE_PAGES_URL}</a>（推荐）
	<br>
	<a href={GITHUB_PAGES_URL} target="_blank">{GITHUB_PAGES_URL}</a>（大陆可能无法访问）
	</p>

	<h2>
		网页自述
	</h2>

	<div class="markdown-body">
		<ReadmeContent />
	</div>
</Layout>
