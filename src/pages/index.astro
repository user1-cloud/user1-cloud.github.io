---
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE, fmtNum } from '../consts';
import { computeSiteStats } from '../lib/blogStats';
import { getRepoLanguages } from '../lib/repoStats';
import Layout from '../layouts/BlogPost.astro';
import JsonLd from '../components/blog/JsonLd.astro';
import BlogList from '../components/blog/BlogList.astro';
import GitHubContributions from '../components/github/GitHubContributions.astro';
import MonthlyChart from '../components/github/MonthlyChart.astro';
import GitHubRepoStats from '../components/github/GitHubRepoStats.astro';
import GitHubLanguages from '../components/github/GitHubLanguages.astro';

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_TITLE,
  description: SITE_DESCRIPTION,
  url: new URL('/', Astro.site).href,
};

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const stats = computeSiteStats(allPosts);
const { repoLanguages, totalRepoLines } = getRepoLanguages();
---

<Layout
  title="u1的书房"
  description={SITE_DESCRIPTION}
  pubDate={new Date()}
>
  <JsonLd slot="head" data={websiteLd} />

  <div class="home-page">
    <!-- 欢迎语 -->
    <section class="welcome">
      <h2 class="mk-title" style="display:inline;">你好！</h2>
      <h2 style="display:inline;">我是 user1-cloud</h2>
      <p>欢迎来到我的个人主页。</p>
    </section>

    <!-- 统计 -->
    <h2 class="mk-title sr-only">数据统计</h2>

    <section class="site-stats">
      <div class="stat-card fade-up-on-scroll">
        <div class="stat-number">{stats.totalArticles}</div>
        <div class="stat-label">文章</div>
      </div>
      <div class="stat-card fade-up-on-scroll" style="animation-delay: 0.05s">
        <div class="stat-number">{stats.totalCategories}</div>
        <div class="stat-label">分类</div>
      </div>
      <div class="stat-card fade-up-on-scroll" style="animation-delay: 0.1s">
        <div class="stat-number">{stats.totalTags}</div>
        <div class="stat-label">标签</div>
      </div>
      <div class="stat-card fade-up-on-scroll" style="animation-delay: 0.15s">
        <div class="stat-number">{stats.daysSinceLaunch}</div>
        <div class="stat-label">建站天数</div>
      </div>
      <div class="stat-card fade-up-on-scroll" style="animation-delay: 0.2s">
        <div class="stat-number">{fmtNum(stats.totalWords)}</div>
        <div class="stat-label">累计字数</div>
      </div>
      <div class="stat-card fade-up-on-scroll" style="animation-delay: 0.25s">
        <div class="stat-number">{fmtNum(totalRepoLines)}</div>
        <div class="stat-label">代码行数</div>
      </div>
    </section>

    <!-- 月度发文折线图 -->
    <MonthlyChart labels={stats.monthLabels} counts={stats.monthCounts} />

    <!-- 仓库语言构成 -->
    <GitHubRepoStats languages={repoLanguages} totalLines={totalRepoLines} />

    <!-- GitHub 个人语言构成 -->
    <GitHubLanguages />

    <!-- GitHub 贡献墙 -->
    <GitHubContributions />

    <!-- 近期博客 -->
    <section class="recent-posts">
      <h2 class="mk-title section-title">近期文章</h2>
      <BlogList sort="time" posts={recentPosts} />
    </section>
  </div>
</Layout>

<style>
  .home-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem;
    text-align: center;
  }

  .welcome {
    margin-bottom: 2rem;
  }

  .welcome h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    color: var(--foreground-light);
  }

  .welcome p {
    color: var(--foreground-dark);
    font-size: 1.1rem;
  }

  /* 站点统计卡片 — 3 列网格 */
  .site-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin: 2.5rem auto;
    max-width: 760px;
  }

  .stat-card {
    background: rgba(var(--muted-rgb), 0.4);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem 1rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .stat-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
  }

  .stat-number {
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--accent-light);
    line-height: 1.2;
  }

  .stat-label {
    font-size: 0.9rem;
    color: var(--foreground-dark);
    margin-top: 0.3rem;
  }

  .section-title {
    font-size: 1.4rem;
    margin: 3rem 0 1.5rem;
    color: var(--foreground-light);
    text-align: center;
  }

  /* 图表和统计卡片之间的间距 */
  .home-page :global(.monthly-chart-card),
  .home-page :global(.repo-stats-card),
  .home-page :global(#gh-languages-root) {
    margin-top: 1.5rem;
  }

  @media (max-width: 760px) {
    .site-stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .stat-card {
      padding: 1rem 0.8rem;
    }

    .stat-number {
      font-size: 1.8rem;
    }
  }

  @media (max-width: 420px) {
    .site-stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.6rem;
    }

    .stat-card {
      padding: 0.8rem 0.5rem;
    }

    .stat-number {
      font-size: 1.5rem;
    }
  }
</style>
