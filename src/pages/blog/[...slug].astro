---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import BlogCard from '../../components/BlogCard.astro';
import JsonLd from '../../components/JsonLd.astro';
import { resolveDirs } from '../../lib/utils';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

const postUrl = new URL(`/blog/${post.id}/`, Astro.site).href;
const baseUrl = new URL('/', Astro.site).href;
const blogUrl = new URL('/blog/', Astro.site).href;

let imageUrl: string | undefined;
if (post.data.heroImage) {
	imageUrl = new URL(post.data.heroImage.src, Astro.site).href;
}

const breadcrumbItems = [
	{ '@type': 'ListItem', position: 1, name: '首页', item: baseUrl },
	{ '@type': 'ListItem', position: 2, name: '博客', item: blogUrl },
];

const { dir1, dir2 } = resolveDirs(post);

let pos = 3;
if (dir1) {
	const dir1Url = new URL(`/blog/?dir1=${encodeURIComponent(dir1)}`, Astro.site).href;
	breadcrumbItems.push({ '@type': 'ListItem', position: pos++, name: dir1, item: dir1Url });
}
if (dir2) {
	const dir2Url = new URL(`/blog/?dir1=${encodeURIComponent(dir1)}&dir2=${encodeURIComponent(dir2)}`, Astro.site).href;
	breadcrumbItems.push({ '@type': 'ListItem', position: pos++, name: dir2, item: dir2Url });
}
breadcrumbItems.push({ '@type': 'ListItem', position: pos, name: post.data.title });

const blogPostingLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: post.data.title,
	description: post.data.description,
	...(imageUrl && { image: imageUrl }),
	datePublished: post.data.pubDate.toISOString(),
	...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
	author: {
		'@type': 'Person',
		name: 'user1-cloud',
		url: new URL('/about/', Astro.site).href,
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': postUrl,
	},
	...(post.data.tags.length > 0 && { keywords: post.data.tags.join(', ') }),
};

const breadcrumbLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: breadcrumbItems,
};
---

<BlogPost {...post.data}>
	<JsonLd slot="head" data={blogPostingLd} />
	<JsonLd slot="head" data={breadcrumbLd} />

	<Content components={{
		 BlogCard: BlogCard
	}} />
</BlogPost>
