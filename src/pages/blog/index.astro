---
import { DIR1_ORDER, DIR2_ORDER } from '../../consts';
import Layout from '../../layouts/BlogPost.astro';
import BlogList from '../../components/blog/BlogList.astro';
import JsonLd from '../../components/blog/JsonLd.astro';

const dirOrder = {
  dir1: [...DIR1_ORDER, '未分类'],
  dir2: DIR2_ORDER,
};

const collectionPageLd = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: '博客目录',
	description: '这里可以看到我的所有博客和文章',
	url: new URL('/blog/', Astro.site).href,
};
---

<Layout
	title="目录"
	description="这里可以看到我的所有博客和文章"
	pubDate={new Date()}
>
	<JsonLd slot="head" data={collectionPageLd} />

	<div style="text-align: center; margin-bottom: 1.5rem;">
		<a href="/blog/tags/" style="color: var(--accent-light); text-decoration: none; font-size: 0.9rem;">
			查看所有标签 →
		</a>
	</div>

	<BlogList sort="dir" dirOrder={dirOrder} />
</Layout>
